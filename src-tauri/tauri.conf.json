{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EchoTrans",
  "version": "0.2.0",
  "identifier": "com.echotrans.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "popup",
        "url": "index.html",
        "title": "EchoTrans",
        "width": 440,
        "height": 380,
        "minWidth": 300,
        "minHeight": 180,
        "visible": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "transparent": true,
        "shadow": false
      },
      {
        "label": "settings",
        "url": "settings.html",
        "title": "EchoTrans 设置",
        "width": 620,
        "height": 720,
        "minWidth": 480,
        "minHeight": 520,
        "visible": false,
        "center": true
      },
      {
        "label": "snip",
        "url": "snip.html",
        "title": "EchoTrans 截屏",
        "width": 800,
        "height": 600,
        "visible": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "transparent": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    }
  }
}
